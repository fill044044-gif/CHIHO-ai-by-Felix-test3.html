<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>CHIHO EXPERIENCE — WOK & ROULETTE</title>
<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    min-height: 100vh;
    background: radial-gradient(circle at 20% 30%, #0a0f1a, #030507);
    font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Roboto', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
  }

  .glass-panel {
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
    background: rgba(10, 12, 18, 0.75);
    backdrop-filter: blur(10px);
    border-radius: 48px;
    border: 1px solid rgba(255, 43, 43, 0.3);
    box-shadow: 0 25px 45px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,43,43,0.1);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .container {
    padding: 28px 24px 36px;
  }

  .title {
    font-size: 28px;
    font-weight: 800;
    text-align: center;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #ff3b3b, #ff8c2c);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 2px 5px rgba(255, 43, 43, 0.3);
    margin-bottom: 20px;
  }

  .btn {
    display: block;
    width: 100%;
    padding: 14px 20px;
    margin: 12px 0;
    font-size: 18px;
    font-weight: bold;
    border: none;
    border-radius: 60px;
    background: linear-gradient(95deg, #ff2b2b, #e61a1a);
    color: white;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 8px 18px rgba(255, 43, 43, 0.3);
    letter-spacing: 0.5px;
  }

  .btn:active {
    transform: scale(0.96);
    box-shadow: 0 3px 8px rgba(255, 43, 43, 0.5);
  }

  .btn-outline {
    background: transparent;
    border: 2px solid #ff4d4d;
    box-shadow: none;
    color: #ff5e5e;
    margin-top: 8px;
  }

  .btn-outline:active {
    background: rgba(255, 43, 43, 0.2);
  }

  .result-card {
    background: rgba(20, 22, 32, 0.7);
    border-radius: 32px;
    padding: 18px;
    margin: 20px 0 10px;
    text-align: center;
    backdrop-filter: blur(4px);
  }

  .food-img {
    width: 100%;
    max-height: 260px;
    object-fit: cover;
    border-radius: 28px;
    margin: 16px 0;
    box-shadow: 0 12px 28px rgba(0,0,0,0.4);
    border: 1px solid rgba(255,80,80,0.4);
    transition: transform 0.2s;
  }

  .code {
    background: #0c0f17;
    padding: 12px 16px;
    border-radius: 48px;
    font-family: monospace;
    font-size: 18px;
    letter-spacing: 1px;
    color: #00ffcc;
    text-shadow: 0 0 5px #00ffaa;
    margin: 15px 0;
    border: 1px dashed #ff5a5a;
    word-break: break-all;
  }

  .prize-highlight {
    font-size: 24px;
    font-weight: 800;
    color: #ffd966;
    background: linear-gradient(145deg, #2a1e1e, #1f1212);
    border-radius: 50px;
    padding: 12px;
    margin-top: 10px;
  }

  .hidden {
    display: none;
  }

  .flex-btns {
    display: flex;
    gap: 12px;
    margin-top: 10px;
  }

  .restart-icon {
    background: rgba(255,255,240,0.05);
    backdrop-filter: blur(4px);
    border-radius: 40px;
    padding: 8px 16px;
    font-size: 14px;
    border: 1px solid #ff4d4d60;
    color: #ffa3a3;
    cursor: pointer;
    transition: 0.2s;
    text-align: center;
    font-weight: 600;
  }

  .restart-icon:hover {
    background: #ff2b2b20;
    border-color: #ff6a6a;
    color: white;
  }

  footer {
    margin-top: 20px;
    text-align: center;
    font-size: 12px;
    opacity: 0.6;
  }

  @keyframes pulse {
    0% { opacity: 0.7; transform: scale(0.98);}
    100% { opacity: 1; transform: scale(1);}
  }
  .game-result-area {
    animation: pulse 0.4s ease;
  }
</style>
</head>
<body>

<div class="glass-panel">
  <div class="container">
    <!-- GAME BLOCK -->
    <div id="game">
      <div class="title">🎲 CHIHO ROULETTE 🎲</div>
      <button class="btn" id="spinButton">🎡 КРУТИТЬ КОЛЕСО</button>
      <div id="gameResult" class="result-card"></div>
      <div class="restart-icon" id="globalResetBtn">⟳ НАЧАТЬ ЗАНОВО</div>
    </div>

    <!-- QUIZ BLOCK -->
    <div id="quiz" class="hidden"></div>

    <!-- FINAL RESULT -->
    <div id="final" class="hidden"></div>
    <footer>🔥 CHIHO · Острые моменты с доставкой</footer>
  </div>
</div>

<!-- SOUND EFFECTS (preload) -->
<audio id="click" preload="auto" src="https://assets.mixkit.co/sfx/preview/mixkit-metal-click-1109.mp3"></audio>
<audio id="spinS" preload="auto" src="https://assets.mixkit.co/sfx/preview/mixkit-fast-swoosh-transition-166.mp3"></audio>
<audio id="win" preload="auto" src="https://assets.mixkit.co/sfx/preview/mixkit-arcade-bonus-alert-767.mp3"></audio>

<script>
  // DOM elements
  const gameDiv = document.getElementById('game');
  const quizDiv = document.getElementById('quiz');
  const finalDiv = document.getElementById('final');
  const gameResultDiv = document.getElementById('gameResult');
  const spinBtn = document.getElementById('spinButton');
  const globalReset = document.getElementById('globalResetBtn');

  // Audio elements
  const clickSnd = document.getElementById('click');
  const spinSnd = document.getElementById('spinS');
  const winSnd = document.getElementById('win');

  // Game state
  let spinning = false;
  let quizStep = 0;
  
  // Prize pool
  const prizes = [
    "🌶️ ОСТРЫЙ СОУС",
    "🍰 ДЕСЕРТ ЧИЗКЕЙК",
    "💸 СКИДКА 10%",
    "💥 СКИДКА 20%",
    "🍜 ЛАПША WOK С КРЕВЕТКАМИ"
  ];

  // Quiz questions (vibe check)
  const questions = [
    { q: "🤔 ТЫ СЕЙЧАС?", a: ["🔥 ГОЛОДНЫЙ ВОЛК", "😏 ЛЕГКИЙ ПЕРЕКУС", "😎 ВАЙБОВЫЙ ЧИЛЛ"] },
    { q: "🌶️ ЧЕГО ХОЧЕТСЯ?", a: ["ОСТРОГО ОГНЯ", "СЛАДКОГО КАЙФА", "СЫТНОГО УРАГАНА"] },
    { q: "✨ ТВОЁ НАСТРОЕНИЕ?", a: ["⚡ ЭНЕРГИЯ БУСТ", "😌 ДЗЕН-МОМЕНТ", "🎉 ВЗРЫВ РАДОСТИ"] },
    { q: "🍜 СЕГОДНЯ ТЫ...", a: ["😈 ХИЩНИК УМИ", "🧘 ФИЛОСОФ УДОНА", "🎯 ЦЕЛЕВОЙ ЕДОК"] }
  ];

  // ========== ФИНАЛЬНЫЕ РЕЗУЛЬТАТЫ С РАБОЧИМИ ИЗОБРАЖЕНИЯМИ (аппетитные ссылки) ==========
  const finalResults = [
    {
      text: "🌋 ОСТРЫЙ WOK · ОГОНЬ ВКУСА",
      img: "https://images.pexels.com/photos/1640777/pexels-photo-1640777.jpeg?auto=compress&cs=tinysrgb&w=600",
      alt: "Острый вок с лапшой"
    },
    {
      text: "🍜 РАМЕН · УМАМИ ВЗРЫВ",
      img: "https://images.pexels.com/photos/1279330/pexels-photo-1279330.jpeg?auto=compress&cs=tinysrgb&w=600",
      alt: "Сытный рамен"
    },
    {
      text: "🍰 ТИРАМИСУ · СЛАДКИЙ ФИНАЛ",
      img: "https://images.pexels.com/photos/2224828/pexels-photo-2224828.jpeg?auto=compress&cs=tinysrgb&w=600",
      alt: "Десерт"
    },
    {
      text: "⚡ ЭНЕРДЖИ БАУЛ · БУСТ-БОКС",
      img: "https://images.pexels.com/photos/3728518/pexels-photo-3728518.jpeg?auto=compress&cs=tinysrgb&w=600",
      alt: "Энергетический напиток и закуска"
    },
    {
      text: "🎁 БОНУСНЫЙ КОМБО · ПОДАРОК ОТ ШЕФА",
      img: "https://images.pexels.com/photos/2983098/pexels-photo-2983098.jpeg?auto=compress&cs=tinysrgb&w=600",
      alt: "Эксклюзивное блюдо"
    }
  ];

  // ---------- HELPER FUNCTIONS ----------
  function playSound(soundElement) {
    if (!soundElement) return;
    soundElement.currentTime = 0;
    soundElement.play().catch(e => console.log("Audio play error (user interaction needed):", e));
  }

  // Reset full experience
  function resetFullGame() {
    // stop any pending spin state
    spinning = false;
    quizStep = 0;
    
    // UI visibility
    gameDiv.classList.remove('hidden');
    quizDiv.classList.add('hidden');
    finalDiv.classList.add('hidden');
    
    // Clear game result area, remove any leftover buttons
    gameResultDiv.innerHTML = '';
    
    // reset spin button if needed (re-enable)
    spinBtn.disabled = false;
    spinBtn.textContent = "🎡 КРУТИТЬ КОЛЕСО";
    
    // optional: remove any residual styles
    const anyOldBtn = document.querySelector('.btn-continue');
    if(anyOldBtn) anyOldBtn.remove();
    
    // tiny haptic
    playSound(clickSnd);
  }

  // Generate random promo code
  function generatePromoCode() {
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789';
    let code = 'CHIHO-';
    for(let i = 0; i < 6; i++) {
      code += chars.charAt(Math.floor(Math.random() * chars.length));
    }
    return code;
  }

  // Show final random recommendation
  function showFinalRecommendation() {
    gameDiv.classList.add('hidden');
    quizDiv.classList.add('hidden');
    finalDiv.classList.remove('hidden');
    
    const randomIndex = Math.floor(Math.random() * finalResults.length);
    const result = finalResults[randomIndex];
    const promo = generatePromoCode();
    
    playSound(winSnd);
    
    finalDiv.innerHTML = `
      <div class="title" style="font-size: 24px;">✨ ТВОЙ ИДЕАЛЬНЫЙ ВЫБОР ✨</div>
      <div class="result-card">
        <div style="font-size: 26px; font-weight: bold; margin-bottom: 8px;">${result.text}</div>
        <img class="food-img" src="${result.img}" alt="${result.alt}" loading="lazy" onerror="this.src='https://placehold.co/600x400/2a1a1a/ff6666?text=WOK+LOVE'">
        <div class="code">🎫 ПРОМОКОД: <strong>${promo}</strong></div>
        <button class="btn" id="orderBtn">🍜 ЗАКАЗАТЬ СЕЙЧАС</button>
        <div class="flex-btns" style="margin-top: 12px;">
          <div class="restart-icon" id="finalRestartBtn" style="flex:1; text-align:center;">⟳ ИГРАТЬ СНОВА</div>
        </div>
        <div style="font-size: 13px; margin-top: 12px; opacity:0.8;">*код действует 30 минут на первый заказ</div>
      </div>
    `;
    
    // attach order button event
    const orderBtn = document.getElementById('orderBtn');
    if(orderBtn) {
      orderBtn.addEventListener('click', () => {
        playSound(clickSnd);
        alert(`✅ Спасибо! Промокод ${promo} активирован. Переходим к оформлению заказа 🔥`);
      });
    }
    const finalRestart = document.getElementById('finalRestartBtn');
    if(finalRestart) {
      finalRestart.addEventListener('click', () => {
        playSound(clickSnd);
        resetFullGame();
      });
    }
  }

  // Render quiz step
  function renderQuizStep() {
    if(quizStep < questions.length) {
      const qData = questions[quizStep];
      const buttonsHtml = qData.a.map(answer => 
        `<button class="btn quiz-option-btn" data-answer="${answer}">${answer}</button>`
      ).join('');
      
      quizDiv.innerHTML = `
        <div class="title" style="font-size: 26px;">🍜 ВАЙБ-ТЕСТ</div>
        <div class="result-card" style="margin-bottom: 12px;">
          <div style="font-size: 24px; font-weight: 600; margin-bottom: 18px;">${qData.q}</div>
          ${buttonsHtml}
        </div>
        <div class="restart-icon" id="quizResetBtn" style="margin-top: 10px;">⟳ РЕСТАРТ</div>
      `;
      
      // attach event listeners to quiz buttons
      const optionBtns = document.querySelectorAll('.quiz-option-btn');
      optionBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          playSound(clickSnd);
          quizStep++;
          renderQuizStep();
        });
      });
      
      const quizReset = document.getElementById('quizResetBtn');
      if(quizReset) {
        quizReset.addEventListener('click', () => {
          playSound(clickSnd);
          resetFullGame();
        });
      }
    } else {
      // quiz finished → show final recommendation
      showFinalRecommendation();
    }
  }

  // Start quiz (after winning prize)
  function startQuiz() {
    // reset quiz step before start
    quizStep = 0;
    gameDiv.classList.add('hidden');
    quizDiv.classList.remove('hidden');
    finalDiv.classList.add('hidden');
    renderQuizStep();
  }

  // SPIN MECHANICS with cool result
  function spinWheel() {
    if(spinning) return;
    spinning = true;
    spinBtn.disabled = true;
    spinBtn.textContent = "🌀 КРУЧУ...";
    
    playSound(clickSnd);
    playSound(spinSnd);
    
    // clear previous result before new spin
    gameResultDiv.innerHTML = `<div style="padding: 16px;">🎲 КОЛЕСО ВРАЩАЕТСЯ... 🎲</div>`;
    
    setTimeout(() => {
      const randomPrize = prizes[Math.floor(Math.random() * prizes.length)];
      playSound(winSnd);
      
      let prizeEmoji = "";
      if(randomPrize.includes("СОУС")) prizeEmoji = "🌶️";
      else if(randomPrize.includes("ДЕСЕРТ")) prizeEmoji = "🍰";
      else if(randomPrize.includes("СКИДКА")) prizeEmoji = "💸";
      else if(randomPrize.includes("ЛАПША")) prizeEmoji = "🍜";
      else prizeEmoji = "🎁";
      
      gameResultDiv.innerHTML = `
        <div class="prize-highlight">
          🎉 ВЫ ВЫИГРАЛИ! 🎉<br>
          <span style="font-size: 28px;">${prizeEmoji} ${randomPrize}</span>
        </div>
        <button class="btn" id="continueAfterSpin" style="background: #d4411e; margin-top: 18px;">🔥 ПРОДОЛЖИТЬ ПУТЬ 🔥</button>
      `;
      
      const continueBtn = document.getElementById('continueAfterSpin');
      if(continueBtn) {
        continueBtn.addEventListener('click', () => {
          playSound(clickSnd);
          startQuiz();
        });
      }
      
      spinning = false;
      spinBtn.disabled = false;
      spinBtn.textContent = "🎡 КРУТИТЬ КОЛЕСО";
    }, 1200);
  }

  // -------- EVENT HANDLERS ----------
  spinBtn.addEventListener('click', spinWheel);
  
  // global reset from bottom
  globalReset.addEventListener('click', () => {
    // reset everything
    resetFullGame();
    // also kill any ongoing spin timeout if active? but just in case reset flag
    spinning = false;
    spinBtn.disabled = false;
    spinBtn.textContent = "🎡 КРУТИТЬ КОЛЕСО";
  });
  
  // ensure that if by any chance the quiz is active, reset works
  // Initialize clean state (only game visible)
  resetFullGame();
  
  // Bonus: prevent image breaking - fallback for unsplash/pexels just in case
  // we already have onerror in final, but also add style for images
  window.addEventListener('load', () => {
    // small polish: add dynamic meta
    document.body.style.opacity = '1';
  });
  
  // fix for sound contexts (some browsers need first click to enable audio)
  // we will also try to pre-warm audio but not needed, all sounds are user-initiated
  
  // Additional: restart from final screen also handled dynamically
  // Also if user wants to reset during spin? we prevent reset while spinning? but reset will just hide divs, but spin setTimeout may still run
  // Improved reset to avoid conflicts:
  const originalReset = resetFullGame;
  window.resetFullGame = function() {
    spinning = false;
    if(spinBtn) spinBtn.disabled = false;
    originalReset();
  };
  resetFullGame();
  
  // micro fix for edge: if startQuiz called twice we avoid duplicate renders
  // also add proper visibility
  console.log("CHIHO EXPERIENCE READY — ВКУСНЫЙ ВАЙБ");
</script>
</body>
</html>
